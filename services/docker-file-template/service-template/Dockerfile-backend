FROM eclipse-temurin:17-jre-jammy

ARG SERVICE_DIR=service-template
ARG APP_PORT=8080

WORKDIR /app

# 手动打包后，将 Jar 放到服务目录下，并统一命名为 app.jar。
COPY ${SERVICE_DIR}/app.jar /app/app.jar

# 外部配置文件可按需挂载到 /app/config。
RUN mkdir -p /app/config

ENV SPRING_PROFILES_ACTIVE=prod

EXPOSE ${APP_PORT}

ENTRYPOINT ["sh", "-c", "java -jar app.jar --spring.profiles.active=${SPRING_PROFILES_ACTIVE} --spring.config.location=classpath:application.yaml,classpath:application.yml,optional:file:/app/config/application.yaml,optional:file:/app/config/application.yml"]
